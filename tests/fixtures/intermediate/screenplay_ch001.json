  "data": {
    "chapter_index": 0,
    "chapter_title": "第一章 初入江湖",
    "utterances": [
      {"id": "u0001", "speaker_id": "narrator", "text": "林凡站在山门前，仰望着眼前巍峨的宗门大殿。", "is_dialogue": false},
      {"id": "u0002", "speaker_id": "unknown", "text": "你就是新来的弟子？", "is_dialogue": true},
      {"id": "u0003", "speaker_id": "narrator", "text": "一个年轻人走了过来，语气中带着几分不屑。", "is_dialogue": false},
      {"id": "u0004", "speaker_id": "林凡", "text": "在下林凡，前来拜山。", "is_dialogue": true},
      {"id": "u0005", "speaker_id": "unknown", "text": "哼，这里可不是什么人都能进的地方。", "is_dialogue": true},
      {"id": "u0006", "speaker_id": "narrator", "text": "一阵清风吹过，吹动了林凡的衣角。他深吸一口气，目光变得坚定起来。", "is_dialogue": false}
    ]
  }
